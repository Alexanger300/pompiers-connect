# === APPLICATION ===
NODE_ENV=development
PORT=4000

# === SUPABASE ===
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_key_here

# === JWT SECRETS ===
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# === SESSION CONFIGURATION ===
# Validity period in days (default: 30)
SESSION_EXPIRY_DAYS=30

# === SMTP / EMAIL ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_password_here
SMTP_FROM=no-reply@example.com

# === MOBILE NOTIFICATIONS CALLBACK ===
MOBILE_NOTIFICATION_CALLBACK_URL=https://your-mobile-callback.example.com/notifications
MOBILE_NOTIFICATION_CALLBACK_SECRET=your_shared_secret_here

# === OPTIONAL STAFF SEEDING ===
SEED_ADMIN_EMAIL=admin@pompiers-connect.local
SEED_ADMIN_NOM=Systeme
SEED_ADMIN_PRENOM=Admin
SEED_ADMIN_TELEPHONE=
SEED_SUPERVISEUR_EMAIL=superviseur@pompiers-connect.local
SEED_SUPERVISEUR_NOM=Systeme
SEED_SUPERVISEUR_PRENOM=Superviseur
SEED_SUPERVISEUR_TELEPHONE=
